# SURP API — variables de entorno
# Copiar a .env (no commiteable) y ajustar.
#
# Validación: src/config/env.schema.ts (Zod). Fail-closed en producción.

# ============================================================================
# Core
# ============================================================================
NODE_ENV=development
PORT=3201
LOG_LEVEL=info

# CORS — lista separada por coma de orígenes permitidos. Vacío = sin CORS.
CORS_ORIGIN=http://localhost:3200

# ============================================================================
# Modo worker
# ============================================================================
# 'true' arranca como BullMQ worker sin HTTP listener.
# WORKER_MODE=true

# ============================================================================
# Database (obligatorio en cualquier modo)
# ============================================================================
DATABASE_URL=postgres://postgres:test@localhost:5499/surp
DATABASE_POOL_MAX=10

# ============================================================================
# JWT — OBLIGATORIO en todos los entornos.
# Mínimo 32 chars en dev/test. Mínimo 64 chars en NODE_ENV=production.
# Generar con: node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
# En staging/prod este valor vive en Azure Key Vault.
# ============================================================================
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================================
# Storage
# ============================================================================
# Driver de almacenamiento de archivos.
#   local — disco bajo STORAGE_LOCAL_ROOT (default ./storage-data). URLs
#           firmadas con HMAC servidas por /storage/local. Para dev/test/CI.
#   azure — Azure Blob Storage (stub hoy; se implementa con deploy a staging).
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage-data

# Secret HMAC para firmar URLs de descarga del LocalStorageAdapter.
# OBLIGATORIO cuando STORAGE_DRIVER=local. Mínimo 32 caracteres.
# Generar con: openssl rand -hex 32
STORAGE_LOCAL_HMAC_SECRET=

# URL base pública del API — usada para construir links de descarga firmados.
# En dev = http://localhost:3201 (donde escucha la API).
STORAGE_LOCAL_PUBLIC_URL=http://localhost:3201
