# Conexión a la BD del legacy SURP (SQL Server)
# Copiar a .env.legacy.local y completar con valores reales.
# NUNCA comitear .env.legacy.local.
#
# Acceso estrictamente de SOLO LECTURA. Jamás INSERT/UPDATE/DELETE/DDL.
# Las credenciales ORIGINALES viven en el propio código legacy
# (SURP.EF/SACLContext.cs y appsettings.json de SURP.WEB / SURP.API).

# --- DEV ---
LEGACY_DEV_SERVER=
LEGACY_DEV_PORT=
LEGACY_DEV_DATABASE=
LEGACY_DEV_USER=
LEGACY_DEV_PASSWORD=

# --- PROD ---
LEGACY_PROD_SERVER=
LEGACY_PROD_PORT=
LEGACY_PROD_DATABASE=
LEGACY_PROD_USER=
LEGACY_PROD_PASSWORD=
